<!DOCTYPE Robei>
<Module Category="Current" Class="module" Code="    localparam integer SIM_CLK_HALF_PERIOD_NS = 1;&#xa;    localparam integer PERF_CLK_PERIOD_NS     = 10;&#xa;    localparam integer PERF_CLK_FREQ_MHZ      = 1000 / PERF_CLK_PERIOD_NS;&#xa;    localparam integer PERF_CLK_FREQ_HZ       = PERF_CLK_FREQ_MHZ * 1000000;&#xa;&#xa;    localparam integer DS_DATA_W        = 8;&#xa;    localparam integer DS_COL           = 10;&#xa;    localparam integer DS_ROW           = 49;&#xa;    localparam integer PIXELS_PER_FRAME = DS_COL * DS_ROW;&#xa;    localparam integer REPEAT_PER_RUN   = 64;&#xa;    localparam integer RUN_COUNT        = 2;&#xa;    localparam integer TOTAL_IN_BEATS   = PIXELS_PER_FRAME * REPEAT_PER_RUN * RUN_COUNT;&#xa;    localparam integer EXPECTED_OUTPUTS = RUN_COUNT;&#xa;    localparam integer FC_ACC_W         = 40;&#xa;    localparam integer WAIT_MAX_CYCLES  = 5000000;&#xa;&#xa;    localparam integer ENABLE_RANDOM_BACKPRESSURE = 0;&#xa;    localparam integer OUT_READY_PROB_PERCENT     = 80;&#xa;    localparam integer SHOW_EVENT_LOG             = 1;&#xa;&#xa;    localparam INPUT_FILE = &quot;./data/pixel_input/input_pixels.memh&quot;;&#xa;&#xa;    reg [DS_DATA_W-1:0] input_mem [0:PIXELS_PER_FRAME-1];&#xa;&#xa;    integer cycle_count;&#xa;    integer send_idx;&#xa;    integer launched_runs;&#xa;    integer in_fire_count;&#xa;    integer out_fire_count;&#xa;    integer first_in_cycle;&#xa;    integer input_done_cycle;&#xa;    integer first_out_cycle;&#xa;    integer last_out_cycle;&#xa;    integer input_stall_cycles;&#xa;    integer output_stall_cycles;&#xa;    integer timeout_flag;&#xa;    integer run_idx;&#xa;    integer rand_val;&#xa;&#xa;    integer input_duration_cycles;&#xa;    integer first_output_latency_cycles;&#xa;    integer final_latency_cycles;&#xa;    integer avg_inference_cycles;&#xa;    integer avg_inference_time_ns;&#xa;    integer throughput_est_fps;&#xa;    integer in_beats_per_1000_cycles;&#xa;    integer out_beats_per_1000_cycles;&#xa;&#xa;    reg send_done;&#xa;    reg first_in_seen;&#xa;    reg first_out_seen;&#xa;    reg [7:0] final_class_reg;&#xa;    reg signed [FC_ACC_W-1:0] final_score_reg;&#xa;&#xa;    wire signed [FC_ACC_W-1:0] out_score_s = $signed(out_score);&#xa;&#xa;    always #SIM_CLK_HALF_PERIOD_NS clk = ~clk;&#xa;&#xa;    task pulse_start;&#xa;    begin&#xa;        @(negedge clk);&#xa;        start = 1'b1;&#xa;        @(negedge clk);&#xa;        start = 1'b0;&#xa;    end&#xa;    endtask&#xa;&#xa;    initial begin&#xa;        clk                       = 1'b0;&#xa;        rst_n                     = 1'b0;&#xa;        start                     = 1'b0;&#xa;        in_valid                  = 1'b0;&#xa;        in_pixel                  = {DS_DATA_W{1'b0}};&#xa;        out_ready                 = 1'b1;&#xa;        cycle_count               = 0;&#xa;        send_idx                  = 0;&#xa;        launched_runs             = 0;&#xa;        in_fire_count             = 0;&#xa;        out_fire_count            = 0;&#xa;        first_in_cycle            = -1;&#xa;        input_done_cycle          = -1;&#xa;        first_out_cycle           = -1;&#xa;        last_out_cycle            = -1;&#xa;        input_stall_cycles        = 0;&#xa;        output_stall_cycles       = 0;&#xa;        timeout_flag              = 0;&#xa;        send_done                 = 1'b0;&#xa;        first_in_seen             = 1'b0;&#xa;        first_out_seen            = 1'b0;&#xa;        final_class_reg           = 8'd0;&#xa;        final_score_reg           = {FC_ACC_W{1'b0}};&#xa;        input_duration_cycles     = -1;&#xa;        first_output_latency_cycles = -1;&#xa;        final_latency_cycles      = -1;&#xa;        avg_inference_cycles      = 0;&#xa;        avg_inference_time_ns     = 0;&#xa;        throughput_est_fps        = 0;&#xa;        in_beats_per_1000_cycles  = 0;&#xa;        out_beats_per_1000_cycles = 0;&#xa;&#xa;        $readmemh(INPUT_FILE, input_mem, 0, PIXELS_PER_FRAME-1);&#xa;&#xa;        repeat (6) @(posedge clk);&#xa;        @(negedge clk);&#xa;        rst_n = 1'b1;&#xa;        repeat (2) @(posedge clk);&#xa;&#xa;        for (run_idx = 0; run_idx &lt; RUN_COUNT; run_idx = run_idx + 1) begin&#xa;            if (run_idx > 0) begin&#xa;                wait (send_idx >= (run_idx * PIXELS_PER_FRAME * REPEAT_PER_RUN));&#xa;                wait (busy == 1'b0);&#xa;                repeat (2) @(posedge clk);&#xa;            end&#xa;&#xa;            pulse_start();&#xa;            launched_runs = launched_runs + 1;&#xa;            if (SHOW_EVENT_LOG != 0) begin&#xa;                $display(&quot;[TB] launch run %0d at cycle %0d&quot;, run_idx, cycle_count);&#xa;            end&#xa;        end&#xa;&#xa;        while ((out_fire_count &lt; EXPECTED_OUTPUTS) &amp;&amp; (cycle_count &lt; WAIT_MAX_CYCLES)) begin&#xa;            @(posedge clk);&#xa;        end&#xa;&#xa;        if (out_fire_count &lt; EXPECTED_OUTPUTS) begin&#xa;            timeout_flag = 1;&#xa;            $display(&quot;[TB][TIMEOUT] cycle_count=%0d, out_fire_count=%0d, expected=%0d&quot;, cycle_count, out_fire_count, EXPECTED_OUTPUTS);&#xa;        end else begin&#xa;            timeout_flag = 0;&#xa;        end&#xa;&#xa;        if ((first_in_cycle >= 0) &amp;&amp; (input_done_cycle >= first_in_cycle)) begin&#xa;            input_duration_cycles = input_done_cycle - first_in_cycle + 1;&#xa;        end&#xa;        if ((first_in_cycle >= 0) &amp;&amp; (first_out_cycle >= first_in_cycle)) begin&#xa;            first_output_latency_cycles = first_out_cycle - first_in_cycle;&#xa;        end&#xa;        if ((first_in_cycle >= 0) &amp;&amp; (last_out_cycle >= first_in_cycle)) begin&#xa;            final_latency_cycles = last_out_cycle - first_in_cycle;&#xa;        end&#xa;        if (out_fire_count > 0) begin&#xa;            avg_inference_cycles  = (last_out_cycle - first_in_cycle + 1) / out_fire_count;&#xa;            avg_inference_time_ns = avg_inference_cycles * PERF_CLK_PERIOD_NS;&#xa;        end&#xa;        if (avg_inference_cycles > 0) begin&#xa;            throughput_est_fps = PERF_CLK_FREQ_HZ / avg_inference_cycles;&#xa;        end&#xa;        if ((out_fire_count > 0) &amp;&amp; (cycle_count > 0)) begin&#xa;            in_beats_per_1000_cycles  = (in_fire_count * 1000) / cycle_count;&#xa;            out_beats_per_1000_cycles = (out_fire_count * 1000) / cycle_count;&#xa;        end&#xa;&#xa;        $display(&quot;&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;REPORT SCREENSHOT 4-1 : SIM CONFIG&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;PERF_CLK_PERIOD_NS      : %0d&quot;, PERF_CLK_PERIOD_NS);&#xa;        $display(&quot;EQUIV_FREQ_MHZ          : %0d&quot;, PERF_CLK_FREQ_MHZ);&#xa;        $display(&quot;MFCC_ROW                : %0d&quot;, DS_ROW);&#xa;        $display(&quot;MFCC_COL                : %0d&quot;, DS_COL);&#xa;        $display(&quot;INPUT_BEATS_PER_FRAME   : %0d&quot;, PIXELS_PER_FRAME);&#xa;        $display(&quot;INPUT_REPEAT_PER_RUN    : %0d&quot;, REPEAT_PER_RUN);&#xa;        $display(&quot;RUN_COUNT               : %0d&quot;, RUN_COUNT);&#xa;        $display(&quot;TOTAL_INPUT_BEATS       : %0d&quot;, TOTAL_IN_BEATS);&#xa;        $display(&quot;EXPECTED_OUTPUTS        : %0d&quot;, EXPECTED_OUTPUTS);&#xa;        $display(&quot;RAND_BACKPRESSURE_EN    : %0d&quot;, ENABLE_RANDOM_BACKPRESSURE);&#xa;        $display(&quot;OUT_READY_PROB_PCT      : %0d&quot;, OUT_READY_PROB_PERCENT);&#xa;&#xa;        $display(&quot;&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;REPORT SCREENSHOT 4-2 : INPUT OUTPUT COUNTS&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;START_CYCLE             : %0d&quot;, first_in_cycle);&#xa;        $display(&quot;INPUT_DONE_CYCLE        : %0d&quot;, input_done_cycle);&#xa;        $display(&quot;FIRST_OUTPUT_CYCLE      : %0d&quot;, first_out_cycle);&#xa;        $display(&quot;FINAL_OUTPUT_CYCLE      : %0d&quot;, last_out_cycle);&#xa;        $display(&quot;INPUT_ACCEPT_COUNT      : %0d&quot;, in_fire_count);&#xa;        $display(&quot;OUTPUT_ACCEPT_COUNT     : %0d&quot;, out_fire_count);&#xa;        if (in_fire_count == TOTAL_IN_BEATS) begin&#xa;            $display(&quot;INPUT_COUNT_MATCH       : PASS&quot;);&#xa;        end else begin&#xa;            $display(&quot;INPUT_COUNT_MATCH       : FAIL&quot;);&#xa;        end&#xa;        if (out_fire_count == EXPECTED_OUTPUTS) begin&#xa;            $display(&quot;OUTPUT_COUNT_MATCH      : PASS&quot;);&#xa;        end else begin&#xa;            $display(&quot;OUTPUT_COUNT_MATCH      : FAIL&quot;);&#xa;        end&#xa;&#xa;        $display(&quot;&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;REPORT SCREENSHOT 4-3 : LATENCY STATS&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;INPUT_DURATION_CYCLES   : %0d&quot;, input_duration_cycles);&#xa;        $display(&quot;FIRST_OUT_LATENCY_CYC   : %0d&quot;, first_output_latency_cycles);&#xa;        $display(&quot;FINAL_LATENCY_CYCLES    : %0d&quot;, final_latency_cycles);&#xa;        $display(&quot;FINAL_LATENCY_NS        : %0d&quot;, final_latency_cycles * PERF_CLK_PERIOD_NS);&#xa;        $display(&quot;FINAL_LATENCY_US        : %0d&quot;, (final_latency_cycles * PERF_CLK_PERIOD_NS) / 1000);&#xa;&#xa;        $display(&quot;&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;REPORT SCREENSHOT 4-4 : THROUGHPUT ESTIMATE&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;AVG_INFERENCE_CYCLES    : %0d&quot;, avg_inference_cycles);&#xa;        $display(&quot;AVG_INFERENCE_TIME_NS   : %0d&quot;, avg_inference_time_ns);&#xa;        $display(&quot;THROUGHPUT_EST_FPS      : %0d&quot;, throughput_est_fps);&#xa;        $display(&quot;IN_BEATS_PER_1000_CYC   : %0d&quot;, in_beats_per_1000_cycles);&#xa;        $display(&quot;OUT_BEATS_PER_1000_CYC  : %0d&quot;, out_beats_per_1000_cycles);&#xa;&#xa;        $display(&quot;&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;REPORT SCREENSHOT 4-5 : BACKPRESSURE STALL STATS&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;INPUT_STALL_CYCLES      : %0d&quot;, input_stall_cycles);&#xa;        $display(&quot;OUTPUT_STALL_CYCLES     : %0d&quot;, output_stall_cycles);&#xa;        $display(&quot;TIMEOUT_FLAG            : %0d&quot;, timeout_flag);&#xa;&#xa;        $display(&quot;&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;REPORT SCREENSHOT 4-6 : FINAL CLASSIFICATION RESULT&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;FINAL_CLASS             : %0d&quot;, final_class_reg);&#xa;        $display(&quot;FINAL_SCORE_HEX         : 0x%h&quot;, final_score_reg);&#xa;        $display(&quot;FINAL_SCORE_SIGNED      : %0d&quot;, final_score_reg);&#xa;        if ((timeout_flag == 0) &amp;&amp; (in_fire_count == TOTAL_IN_BEATS) &amp;&amp; (out_fire_count == EXPECTED_OUTPUTS) &amp;&amp; ((^final_class_reg) !== 1'bx) &amp;&amp; ((^final_score_reg) !== 1'bx)) begin&#xa;            $display(&quot;TEST_RESULT             : PASS&quot;);&#xa;        end else begin&#xa;            $display(&quot;TEST_RESULT             : CHECK_NEEDED&quot;);&#xa;        end&#xa;&#xa;        $display(&quot;&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;REPORT SCREENSHOT 4-7 : PERFORMANCE SUMMARY&quot;);&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;LAUNCHED_RUNS           : %0d&quot;, launched_runs);&#xa;        $display(&quot;INPUT_DATA_COUNT        : %0d&quot;, in_fire_count);&#xa;        $display(&quot;OUTPUT_DATA_COUNT       : %0d&quot;, out_fire_count);&#xa;        $display(&quot;FIRST_OUT_LATENCY_CYC   : %0d&quot;, first_output_latency_cycles);&#xa;        $display(&quot;FINAL_LATENCY_CYCLES    : %0d&quot;, final_latency_cycles);&#xa;        $display(&quot;AVG_INFERENCE_CYCLES    : %0d&quot;, avg_inference_cycles);&#xa;        $display(&quot;THROUGHPUT_EST_FPS      : %0d&quot;, throughput_est_fps);&#xa;        $display(&quot;FINAL_CLASS             : %0d&quot;, final_class_reg);&#xa;        $display(&quot;FINAL_SCORE_SIGNED      : %0d&quot;, final_score_reg);&#xa;        if ((timeout_flag == 0) &amp;&amp; (in_fire_count == TOTAL_IN_BEATS) &amp;&amp; (out_fire_count == EXPECTED_OUTPUTS) &amp;&amp; ((^final_class_reg) !== 1'bx) &amp;&amp; ((^final_score_reg) !== 1'bx)) begin&#xa;            $display(&quot;SUMMARY_RESULT          : PASS&quot;);&#xa;        end else begin&#xa;            $display(&quot;SUMMARY_RESULT          : CHECK_NEEDED&quot;);&#xa;        end&#xa;        $display(&quot;============================================================&quot;);&#xa;        $display(&quot;&quot;);&#xa;&#xa;        #20;&#xa;        $finish;&#xa;    end&#xa;&#xa;    always @(*) begin&#xa;        in_valid = 1'b0;&#xa;        in_pixel = {DS_DATA_W{1'b0}};&#xa;&#xa;        if (rst_n &amp;&amp; !send_done &amp;&amp; (send_idx &lt; TOTAL_IN_BEATS)) begin&#xa;            in_valid = 1'b1;&#xa;            in_pixel = input_mem[send_idx % PIXELS_PER_FRAME];&#xa;        end&#xa;    end&#xa;&#xa;    always @(negedge clk) begin&#xa;        if (!rst_n) begin&#xa;            out_ready &lt;= 1'b1;&#xa;        end else if (ENABLE_RANDOM_BACKPRESSURE != 0) begin&#xa;            rand_val = ($random &amp; 32'h7fffffff) % 100;&#xa;            out_ready &lt;= (rand_val &lt; OUT_READY_PROB_PERCENT) ? 1'b1 : 1'b0;&#xa;        end else begin&#xa;            out_ready &lt;= 1'b1;&#xa;        end&#xa;    end&#xa;&#xa;    always @(posedge clk) begin&#xa;        if (!rst_n) begin&#xa;            cycle_count         &lt;= 0;&#xa;            send_idx            &lt;= 0;&#xa;            send_done           &lt;= 1'b0;&#xa;            in_fire_count       &lt;= 0;&#xa;            out_fire_count      &lt;= 0;&#xa;            first_in_cycle      &lt;= -1;&#xa;            input_done_cycle    &lt;= -1;&#xa;            first_out_cycle     &lt;= -1;&#xa;            last_out_cycle      &lt;= -1;&#xa;            input_stall_cycles  &lt;= 0;&#xa;            output_stall_cycles &lt;= 0;&#xa;            first_in_seen       &lt;= 1'b0;&#xa;            first_out_seen      &lt;= 1'b0;&#xa;            final_class_reg     &lt;= 8'd0;&#xa;            final_score_reg     &lt;= {FC_ACC_W{1'b0}};&#xa;        end else begin&#xa;            cycle_count &lt;= cycle_count + 1;&#xa;&#xa;            if (in_valid &amp;&amp; !in_ready) begin&#xa;                input_stall_cycles &lt;= input_stall_cycles + 1;&#xa;            end&#xa;&#xa;            if (!send_done &amp;&amp; in_valid &amp;&amp; in_ready) begin&#xa;                if (!first_in_seen) begin&#xa;                    first_in_cycle &lt;= cycle_count;&#xa;                    first_in_seen  &lt;= 1'b1;&#xa;                end&#xa;                send_idx      &lt;= send_idx + 1;&#xa;                in_fire_count &lt;= in_fire_count + 1;&#xa;                if (send_idx + 1 >= TOTAL_IN_BEATS) begin&#xa;                    send_done        &lt;= 1'b1;&#xa;                    input_done_cycle &lt;= cycle_count;&#xa;                end&#xa;            end&#xa;&#xa;            if (out_valid &amp;&amp; !out_ready) begin&#xa;                output_stall_cycles &lt;= output_stall_cycles + 1;&#xa;            end&#xa;&#xa;            if (out_valid &amp;&amp; out_ready) begin&#xa;                if (!first_out_seen) begin&#xa;                    first_out_cycle &lt;= cycle_count;&#xa;                    first_out_seen  &lt;= 1'b1;&#xa;                end&#xa;                last_out_cycle  &lt;= cycle_count;&#xa;                final_class_reg &lt;= out_class;&#xa;                final_score_reg &lt;= out_score_s;&#xa;                if (SHOW_EVENT_LOG != 0) begin&#xa;                    $display(&quot;[OUT] idx=%0d cycle=%0d class=%0d score=%0d (0x%h)&quot;, out_fire_count, cycle_count, out_class, out_score_s, out_score);&#xa;                end&#xa;                out_fire_count &lt;= out_fire_count + 1;&#xa;            end&#xa;        end&#xa;    end" Color="#d3d3d3" Comment="" Height="1080" Name="tb_dscnn_perf_report_formal" Parent="0" Timescale="1ns/1ns" Type="test" Width="1600" X="0" Y="0">
 <Module Category="Current" Class="inference_cg" Code="&#x9;localparam DATA_W = POOL_DATA_W;&#xa;    &#xa;    &#xa;  &#xa;&#xa;" Color="#d3d3d3" Comment="" Height="220" Name="inference_cg0" Parameters="DS_DATA_W = DS_DATA_W; //&#xa;DS_COEFF_W = 8; //&#xa;DS_K_H = 10; //&#xa;DS_K_W = 4; //&#xa;DS_COL = DS_COL; //&#xa;DS_ROW = DS_ROW; //&#xa;DS_STRIDE = 2; //&#xa;DS_PAD_TOP = 4; //&#xa;DS_PAD_BOTTOM = 5; //&#xa;DS_PAD_LEFT = 1; //&#xa;DS_PAD_RIGHT = 2; //&#xa;DS_COEFF_GRP_NUM = 64; //&#xa;DS_OUT_WIDTH = 8; //&#xa;DS_MULT_CNT = 1; //&#xa;DS_MULT_FACTOR0 = 12'sd915; //&#xa;PP_ROUNDS = 3; //&#xa;PP_PIXEL_DEPTH = 125; //&#xa;PP_IN_FRAME_SIZE = 64; //&#xa;PP_DW_K_H = 3; //&#xa;PP_DW_K_W = 3; //&#xa;PP_OUT_PIXEL_W = 8; //&#xa;POOL_DATA_W = 8; //&#xa;POOL_ROW_LEN = 25; //&#xa;POOL_ROW_NUM = 5; //&#xa;POOL_CHANNELS = 64; //&#xa;POOL_SUM_W = 16; //&#xa;FC_DATA_W = 8; //&#xa;FC_IN_CH = 64; //&#xa;FC_OUT_CLASS = 12; //&#xa;FC_WEIGHT_W = 8; //&#xa;FC_BIAS_W = 32; //&#xa;FC_ACC_W = FC_ACC_W; //&#xa;FC_Q_MUL = 239; //&#xa;FC_Q_SHIFT = 16; //&#xa;FC_Q_OFFSET = 128; //&#xa;DS_COEFF_FILE = &quot;./data/weights/DS-CNN_dw0.memh&quot;; //&#xa;DS_BIAS_FILE = &quot;./data/bias/DS-CNN_dw0_Fold_bias.hex&quot;; //&#xa;PP_DW_COEFF_FILE = &quot;./data/weights/DS-CNN_pingpong_dw.memh&quot;; //&#xa;PP_PW_COEFF_FILE = &quot;./data/weights/DS-CNN_pingpong_pw.memh&quot;; //&#xa;PP_DW_BIAS_FILE = &quot;./data/bias/DS-CNN_dw_pingpong_bias.hex&quot;; //&#xa;PP_PW_BIAS_FILE = &quot;./data/bias/DS-CNN_pw_pingpong_bias.hex&quot;; //&#xa;FC_WEIGHT_FILE = &quot;./data/DS-CNN_fc.memh&quot;; //&#xa;FC_BIAS_FILE = &quot;./data/DS-CNN_fc_bias.memh&quot;; //&#xa;" Parent="tb_dscnn_perf_report_formal" Type="model" Width="200" X="700" Y="430">
  <Port Color="#faebd7" Connect="" Datasize="DS_DATA_W-1:0" Datatype="wire " Description="" Height="30" Inout="input" Name="in_pixel" Parent="inference_cg0" Side="left" Width="30" X="-0.15" Y="0.0727273"/>
