<!DOCTYPE Robei>
<Module Category="Current" Class="module" Code="&#xa;&#xa;   &#x9;localparam integer RUNS               = 1;&#xa;    localparam integer ROUND_IN_BEATS   = PIXEL_DEPTH * PW_OUT_CH;&#xa;    localparam integer TOTAL_IN_BEATS     = ROUND_IN_BEATS * RUNS;&#xa;&#xa;    localparam INPUT_INIT_FILE      =&quot;./data/pixel_input/input.memh&quot;;&#xa;    &#xa;    &#xa;    &#xa;    localparam PINGPONG_ROUNDS      = 3;&#xa;    localparam PIXEL_DEPTH          = 125;&#xa;    localparam IN_FRAME_SIZE        = 64;&#xa;    localparam IN_DATA_W            = 8;&#xa;    localparam DW_COEFF_W           = 8;&#xa;    localparam DW_K_H               = 3;&#xa;    localparam DW_K_W               = 3;&#xa;    localparam DW_MUL_W             = IN_DATA_W + DW_COEFF_W;&#xa;    localparam DW_SUM_W             = DW_MUL_W + $clog2(DW_K_H*DW_K_W);&#xa;    localparam DW_COL               = 5;&#xa;    localparam DW_ROW               = 25;&#xa;    localparam DW_STRIDE            = 1;&#xa;    localparam DW_PAD_TOP           = (DW_K_H-1)/2;&#xa;    localparam DW_PAD_BOTTOM        = (DW_K_H)/2;&#xa;    localparam DW_PAD_LEFT          = (DW_K_W-1)/2;&#xa;    localparam DW_PAD_RIGHT         = (DW_K_W)/2;&#xa;    localparam DW_COEFF_GRP_NUM     = IN_FRAME_SIZE * (PINGPONG_ROUNDS + 1);&#xa;    localparam DW_FRAME_GRP_NUM     = IN_FRAME_SIZE;&#xa;    localparam DW_MAC_PIPELINE      = 1;&#xa;    localparam DW_COEFF_INIT_FILE   = &quot;./data/weights/DS-CNN_pingpong_dw.memh&quot;;&#xa;    localparam DW_BIAS_INIT_FILE    = &quot;./data/bias/DS-CNN_dw_pingpong_bias.hex&quot;;&#xa;    localparam DW_OUT_WIDTH         = 8;&#xa;    localparam DW_SHIFT_VAL         = 16;&#xa;    localparam DW_BIAS_GROUP_SIZE   = (PINGPONG_ROUNDS + 1);&#xa;    localparam DW_BIAS_GROUP_BITS   = $clog2(DW_BIAS_GROUP_SIZE);&#xa;    localparam DW_BIAS_CH_BITS      = $clog2(IN_FRAME_SIZE);&#xa;    localparam DW_MULT_CNT          = (PINGPONG_ROUNDS + 1);&#xa;    localparam DW_MULT_FACTOR0 &#x9;&#x9;= 12'sd1246;&#xa;    localparam DW_MULT_FACTOR1 &#x9;&#x9;= 12'sd828;&#xa;    localparam DW_MULT_FACTOR2 &#x9;&#x9;= 12'sd652;&#xa;    localparam DW_MULT_FACTOR3 &#x9;&#x9;= 12'sd412;&#xa;    localparam DW_FIFO_DEPTH        = 16;&#xa;    localparam DW_FIFO_AF_LEVEL     = 10;&#xa;    localparam PW_OUT_CH            = 64;&#xa;    localparam PW_COEFF_W           = 8;&#xa;    localparam PW_K_H               = 1;&#xa;    localparam PW_K_W               = 1;&#xa;    localparam PW_MUL_W             = DW_OUT_WIDTH + PW_COEFF_W;&#xa;    localparam PW_SUM_W             = PW_MUL_W + $clog2(PW_K_H*PW_K_W);&#xa;    localparam PW_COEFF_GRP_NUM     = PW_OUT_CH * (PINGPONG_ROUNDS + 1);&#xa;    localparam PW_FRAME_GRP_NUM     = PW_OUT_CH;&#xa;    localparam PW_MAC_PIPELINE      = 1;&#xa;    localparam PW_COEFF_INIT_FILE   = &quot;./data/weights/DS-CNN_pingpong_pw.memh&quot;;&#xa;    localparam PW_BIAS_INIT_FILE    = &quot;./data/bias/DS-CNN_pw_pingpong_bias.hex&quot;;&#xa;    localparam PW_BIAS_GROUP_SIZE   = (PINGPONG_ROUNDS + 1);&#xa;    localparam PW_BIAS_GROUP_BITS   = $clog2(PW_BIAS_GROUP_SIZE);&#xa;    localparam PW_BIAS_CH_BITS      = $clog2(PW_OUT_CH);&#xa;    localparam PW_MULT_CNT          = (PINGPONG_ROUNDS + 1);&#xa;    localparam PW_MULT_FACTOR0 = 12'sd406;&#xa;    localparam PW_MULT_FACTOR1 = 12'sd461;&#xa;    localparam PW_MULT_FACTOR2 = 12'sd442;&#xa;    localparam PW_MULT_FACTOR3 = 12'sd623;&#xa;    localparam PW_FIFO_DEPTH        = 4;&#xa;    localparam PW_FIFO_AF_LEVEL     = 2;&#xa;    localparam RAM_SEGMENTS         = 1;&#xa;    localparam RAM_ONE_DATA_W       = PW_SUM_W + $clog2(PW_OUT_CH);&#xa;    localparam OUT_PIXEL_WIDTH      = 8;&#xa;    &#xa;    &#xa;    &#xa;    reg  [IN_DATA_W-1:0] input_mem [0:TOTAL_IN_BEATS-1];&#xa;&#xa;    integer err_cnt;&#xa;    integer cyc;&#xa;    integer run_idx;&#xa;    integer in_idx;&#xa;&#xa;    // sender state (conv-style)&#xa;    integer send_idx;&#xa;    reg send_done;&#xa;    always #5 clk = ~clk;&#xa;&#xa;    task pulse_start;&#xa;    begin&#xa;        @(negedge clk);&#xa;        start = 1'b1;&#xa;        @(negedge clk);&#xa;        start = 1'b0;&#xa;    end&#xa;    endtask&#xa;&#xa;    initial begin&#xa;        clk = 1'b0;&#xa;        rst_n = 1'b0;&#xa;        start = 1'b0;&#xa;        in_valid = 1'b0;&#xa;        in_pixel = {IN_DATA_W{1'b0}};&#xa;        in_end_all_frame = 1'b0;&#xa;        out_ready = 1'b1;&#xa;        $readmemh(INPUT_INIT_FILE, input_mem, 0, TOTAL_IN_BEATS-1);&#xa;        err_cnt = 0;&#xa;&#xa;        send_idx = 0;&#xa;        send_done = 1'b0;&#xa;&#xa;&#xa;&#xa;        repeat (6) @(posedge clk);&#xa;        @(negedge clk);&#xa;        rst_n = 1'b1;&#xa;        repeat (2) @(posedge clk);&#xa;&#xa;        // start runs sequentially, using combinational sender similar to tb_dw_pw_cac&#xa;        for (run_idx = 0; run_idx &lt; RUNS; run_idx = run_idx + 1) begin&#xa;            &#xa;            // issue start pulse for this run&#xa;            pulse_start();&#xa;&#xa;            // wait until sender has produced this run's worth of beats&#xa;            while (send_idx &lt; (run_idx+1)*ROUND_IN_BEATS) @(posedge clk);&#xa;&#xa;            while(!end_all_frame || !out_valid || !out_ready) @(posedge clk); // wait until all frames are done and output is drained&#xa;        end&#xa;&#xa;        #20; $stop;&#xa;        $finish;&#xa;    end&#xa;&#xa;&#xa;    always @(*) begin&#xa;        in_valid = 1'b0;&#xa;        in_pixel = {IN_DATA_W{1'b0}};&#xa;        in_end_all_frame = 1'b0;&#xa;&#xa;        if (!send_done &amp;&amp; (send_idx &lt; TOTAL_IN_BEATS)) begin&#xa;            in_valid = 1'b1;&#xa;            in_pixel = input_mem[send_idx % ROUND_IN_BEATS];&#xa;            in_end_all_frame = ((send_idx % ROUND_IN_BEATS) == (ROUND_IN_BEATS - 1)) ? 1'b1 : 1'b0;&#xa;        end&#xa;    end&#xa;&#xa;&#xa;    always @(posedge clk) begin&#xa;        if (!rst_n) begin&#xa;            send_idx &lt;= 0;&#xa;            send_done &lt;= 1'b0;&#xa;        end else begin&#xa;            if (!send_done &amp;&amp; in_valid &amp;&amp; in_ready) begin&#xa;                send_idx &lt;= send_idx + 1;&#xa;                if (send_idx + 1 >= TOTAL_IN_BEATS) begin&#xa;                    send_done &lt;= 1'b1;&#xa;                end&#xa;            end&#xa;        end&#xa;    end&#xa;&#xa;    reg [31:0] out_cnt;&#xa;    always @(posedge clk or negedge rst_n) begin&#xa;        if (!rst_n) begin&#xa;            out_cnt &lt;= 32'b0;&#xa;        end else begin&#xa;            if(out_valid &amp;&amp; out_ready) begin&#xa;                $display(&quot;beat %d: PW_out_pixel(Hex): %h ,end_frame: %b,end_all_frame: %b&quot;, out_cnt, out_data, end_frame, end_all_frame);&#xa;                out_cnt &lt;=(out_cnt == (ROUND_IN_BEATS - 1)) ? 0 : out_cnt + 1;&#xa;            end&#xa;        end&#xa;    end" Color="#d3d3d3" Comment="" Height="1080" Name="dw_pw_pingpong_cg_test" Parent="0" Timescale="1ns/1ns" Type="test" Width="1600" X="0" Y="0">
 <Module Category="Current" Class="dw_pw_pingpong_cg" Code="&#xa;    localparam integer SEG_CHANS        = PW_OUT_CH / RAM_SEGMENTS;&#xa;    localparam integer RAM_DATA_W       = SEG_CHANS * RAM_ONE_DATA_W;&#xa;    localparam integer RAM_DEPTH        = PIXEL_DEPTH * RAM_SEGMENTS;&#xa;    localparam integer RAM_ADDR_W       = (RAM_DEPTH &lt;= 1) ? 1 : $clog2(RAM_DEPTH);&#xa;&#x9;localparam integer OUT_WIDTH&#x9;&#x9;   = OUT_PIXEL_WIDTH;&#xa;    localparam integer OUT_W&#x9;&#x9;&#x9;   = RAM_ONE_DATA_W;&#xa;    localparam integer SEGMENTS&#x9;&#x9;   = RAM_SEGMENTS;&#xa;    localparam integer DATA_WIDTH&#x9;   = RAM_DATA_W; &#xa;" Color="#d3d3d3" Comment="" Height="287" Name="dw_pw_pingpong_cg0" Parameters="PINGPONG_ROUNDS = 3; //&#xa;PIXEL_DEPTH = 125; //&#xa;IN_FRAME_SIZE = 64; //&#xa;IN_DATA_W = 8; //&#xa;DW_COEFF_W = 8; //&#xa;DW_K_H = 3; //&#xa;DW_K_W = 3; //&#xa;DW_MUL_W = IN_DATA_W+DW_COEFF_W; //&#xa;DW_SUM_W = DW_MUL_W+$clog2(DW_K_H*DW_K_W); //&#xa;DW_COL = 5; //&#xa;DW_ROW = 25; //&#xa;DW_STRIDE = 1; //&#xa;DW_PAD_TOP = (DW_K_H-1)/2; //&#xa;DW_PAD_BOTTOM = (DW_K_H)/2; //&#xa;DW_PAD_LEFT = (DW_K_W-1)/2; //&#xa;DW_PAD_RIGHT = (DW_K_W)/2; //&#xa;DW_COEFF_GRP_NUM = IN_FRAME_SIZE*(PINGPONG_ROUNDS+1); //&#xa;DW_FRAME_GRP_NUM = IN_FRAME_SIZE; //&#xa;DW_MAC_PIPELINE = 1; //&#xa;DW_COEFF_INIT_FILE = DW_COEFF_INIT_FILE; //&#xa;DW_BIAS_INIT_FILE = DW_BIAS_INIT_FILE; //&#xa;DW_OUT_WIDTH = 8; //&#xa;DW_SHIFT_VAL = 16; //&#xa;DW_BIAS_GROUP_SIZE = (PINGPONG_ROUNDS+1); //&#xa;DW_BIAS_GROUP_BITS = $clog2(DW_BIAS_GROUP_SIZE); //&#xa;DW_BIAS_CH_BITS = $clog2(IN_FRAME_SIZE); //&#xa;DW_MULT_CNT = (PINGPONG_ROUNDS+1); //&#xa;DW_MULT_FACTOR0 = 12'sd1246; //&#xa;DW_MULT_FACTOR1 = 12'sd828; //&#xa;DW_MULT_FACTOR2 = 12'sd652; //&#xa;DW_MULT_FACTOR3 = 12'sd412; //&#xa;DW_FIFO_DEPTH = 16; //&#xa;DW_FIFO_AF_LEVEL = 10; //&#xa;PW_OUT_CH = 64; //&#xa;PW_COEFF_W = 8; //&#xa;PW_K_H = 1; //&#xa;PW_K_W = 1; //&#xa;PW_MUL_W = DW_OUT_WIDTH+PW_COEFF_W; //&#xa;PW_SUM_W = PW_MUL_W+$clog2(PW_K_H*PW_K_W); //&#xa;PW_COEFF_GRP_NUM = PW_OUT_CH*(PINGPONG_ROUNDS+1); //&#xa;PW_FRAME_GRP_NUM = PW_OUT_CH; //&#xa;PW_MAC_PIPELINE = 1; //&#xa;PW_COEFF_INIT_FILE = PW_COEFF_INIT_FILE; //&#xa;PW_BIAS_INIT_FILE = PW_BIAS_INIT_FILE; //&#xa;PW_BIAS_GROUP_SIZE = (PINGPONG_ROUNDS+1); //&#xa;PW_BIAS_GROUP_BITS = $clog2(PW_BIAS_GROUP_SIZE); //&#xa;PW_BIAS_CH_BITS = $clog2(PW_OUT_CH); //&#xa;PW_MULT_CNT = (PINGPONG_ROUNDS+1); //&#xa;PW_MULT_FACTOR0 = 12'sd406; //&#xa;PW_MULT_FACTOR1 = 12'sd461; //&#xa;PW_MULT_FACTOR2 = 12'sd442; //&#xa;PW_MULT_FACTOR3 = 12'sd623; //&#xa;PW_FIFO_DEPTH = 4; //&#xa;PW_FIFO_AF_LEVEL = 2; //&#xa;RAM_SEGMENTS = 1; //&#xa;RAM_ONE_DATA_W = PW_SUM_W+$clog2(PW_OUT_CH); //&#xa;OUT_PIXEL_WIDTH = 8; //&#xa;" Parent="dw_pw_pingpong_cg_test" Type="model" Width="560" X="466.045" Y="406.342">
