<!DOCTYPE Robei>
<Module Category="Current" Class="module" Code="    localparam integer DS_DATA_W        = 8;&#xa;    localparam integer DS_COL           = 10;&#xa;    localparam integer DS_ROW           = 49;&#xa;    localparam integer PIXELS_PER_FRAME = DS_COL * DS_ROW;  // 490&#xa;    localparam integer FC_ACC_W         = 40;&#xa;&#xa;    localparam INPUT_FILE = &quot;./data/pixel_input/input_pixels.memh&quot;;&#xa;&#xa;    // ==========================================&#xa;    // DUT I/O&#xa;    // ==========================================&#xa;&#xa;&#xa;    // ==========================================&#xa;    // 输入数据存储与控制&#xa;    // ==========================================&#xa;    localparam integer RUNS = 64*2;  // 发送64帧&#xa;    localparam integer TOTAL_IN_BEATS = PIXELS_PER_FRAME * RUNS;&#xa;&#xa;    reg [DS_DATA_W-1:0] input_mem [0:PIXELS_PER_FRAME-1];&#xa;&#xa;    integer send_idx;&#xa;    reg     send_done;&#xa;    integer in_beat_cnt;&#xa;&#xa;    // ==========================================&#xa;    // 输出数据存储与统计&#xa;    // ==========================================&#xa;    integer out_beat_cnt;&#xa;    integer out_frame_cnt;&#xa;    integer err_cnt;&#xa;    integer i;&#xa;&#xa;    // ==========================================&#xa;    // 模块例化：inference&#xa;    // ==========================================&#xa;&#xa;&#xa;    // ==========================================&#xa;    // 时钟生成&#xa;    // ==========================================&#xa;    always #1 clk = ~clk;&#xa;&#xa;    // ==========================================&#xa;    // start 脉冲任务&#xa;    // ==========================================&#xa;    task pulse_start;&#xa;    begin&#xa;        @(negedge clk);&#xa;        start = 1'b1;&#xa;        @(negedge clk);&#xa;        start = 1'b0;&#xa;    end&#xa;    endtask&#xa;&#xa;    // ==========================================&#xa;    // 主测试流程&#xa;    // ==========================================&#xa;    initial begin&#xa;        // 初始化&#xa;        clk = 1'b0;&#xa;        rst_n = 1'b0;&#xa;        start = 1'b0;&#xa;        in_valid = 1'b0;&#xa;        in_pixel = {DS_DATA_W{1'b0}};&#xa;        out_ready = 1'b1;&#xa;&#xa;        err_cnt = 0;&#xa;        out_beat_cnt = 0;&#xa;        out_frame_cnt = 0;&#xa;        send_idx = 0;&#xa;        send_done = 1'b0;&#xa;        in_beat_cnt = 0;&#xa;&#xa;        // 加载输入数据&#xa;        $readmemh(INPUT_FILE, input_mem, 0, PIXELS_PER_FRAME-1);&#xa;        repeat (6) @(posedge clk);&#xa;        @(negedge clk);&#xa;        rst_n = 1'b1;&#xa;        repeat (2) @(posedge clk);&#xa;&#xa;        $display(&quot;[TB] Start inference test&quot;);&#xa;&#xa;        // 启动第一帧推理&#xa;        pulse_start();&#xa;        repeat (2) @(posedge clk);&#xa;        wait (busy == 1'b0);&#xa;        repeat (30) @(posedge clk);&#xa;&#xa;        // 启动第二帧（可继续）&#xa;        pulse_start();&#xa;&#xa;        // 等待所有输入发送完成&#xa;        while (!send_done) @(posedge clk);&#xa;&#xa;        // 等待DUT处理完毕&#xa;        wait (busy == 1'b0);&#xa;&#xa;        // 继续等待输出通道清空&#xa;        repeat (20) @(posedge clk);&#xa;&#xa;        // 打印最终统计&#xa;        $display(&quot;\n[Summary]&quot;);&#xa;        $display(&quot;Total output frames: %0d&quot;, out_frame_cnt);&#xa;        $display(&quot;Total beats: %0d&quot;, out_beat_cnt);&#xa;        $display(&quot;Errors: %0d&quot;, err_cnt);&#xa;        $display(&quot;[TB] Inference test finished&quot;);&#xa;        #20; $stop;&#xa;        $finish;&#xa;    end&#xa;&#xa;    // ==========================================&#xa;    // 组合驱动：输入像素（conv-style）&#xa;    // ==========================================&#xa;    always @(*) begin&#xa;        in_valid = 1'b0;&#xa;        in_pixel = {DS_DATA_W{1'b0}};&#xa;&#xa;        if (!send_done &amp;&amp; (send_idx &lt; TOTAL_IN_BEATS)) begin&#xa;            in_valid = 1'b1;&#xa;            in_pixel = input_mem[send_idx % PIXELS_PER_FRAME];&#xa;        end&#xa;    end&#xa;&#xa;    // ==========================================&#xa;    // 发送索引推进（握手驱动）&#xa;    // ==========================================&#xa;    always @(posedge clk) begin&#xa;        if (!rst_n) begin&#xa;            send_idx &lt;= 0;&#xa;            send_done &lt;= 1'b0;&#xa;            in_beat_cnt &lt;= 0;&#xa;        end else begin&#xa;            if (!send_done &amp;&amp; in_valid &amp;&amp; in_ready) begin&#xa;                send_idx &lt;= send_idx + 1;&#xa;                in_beat_cnt &lt;= in_beat_cnt + 1;&#xa;                if (send_idx + 1 >= TOTAL_IN_BEATS) begin&#xa;                    send_done &lt;= 1'b1;&#xa;                end&#xa;            end&#xa;        end&#xa;    end&#xa;&#xa;    // ==========================================&#xa;    // 输出监控：收集分类结果&#xa;    // ==========================================&#xa;    always @(posedge clk) begin&#xa;        if (rst_n &amp;&amp; out_valid &amp;&amp; out_ready) begin&#xa;            out_beat_cnt &lt;= out_beat_cnt + 1;&#xa;            out_frame_cnt &lt;= out_frame_cnt + 1;&#xa;&#xa;            // 显示分类结果&#xa;            $display(&quot;[TB] Frame[%0d] class=%0d score=%0d (0x%x)&quot;, out_frame_cnt, out_class, out_score, out_score);&#xa;&#xa;            // 基本检查：class 应在 0-11 范围&#xa;            if (out_class > 11) begin&#xa;                $display(&quot;[TB_ERROR] Invalid class value: %0d (should be 0-11)&quot;, out_class);&#xa;                err_cnt = err_cnt + 1;&#xa;            end&#xa;        end&#xa;    end&#xa;" Color="#d3d3d3" Comment="" Height="1080" Name="inference_cg_test" Parent="0" Timescale="1ns/1ns" Type="test" Width="1600" X="0" Y="0">
 <Module Category="Current" Class="inference_cg" Code="&#x9;localparam DATA_W = POOL_DATA_W;&#xa;    &#xa;    &#xa;  &#xa;&#xa;" Color="#d3d3d3" Comment="" Height="220" Name="inference_cg0" Parameters="DS_DATA_W = DS_DATA_W; //&#xa;DS_COEFF_W = 8; //&#xa;DS_K_H = 10; //&#xa;DS_K_W = 4; //&#xa;DS_COL = DS_COL; //&#xa;DS_ROW = DS_ROW; //&#xa;DS_STRIDE = 2; //&#xa;DS_PAD_TOP = 4; //&#xa;DS_PAD_BOTTOM = 5; //&#xa;DS_PAD_LEFT = 1; //&#xa;DS_PAD_RIGHT = 2; //&#xa;DS_COEFF_GRP_NUM = 64; //&#xa;DS_OUT_WIDTH = 8; //&#xa;DS_MULT_CNT = 1; //&#xa;DS_MULT_FACTOR0 = 12'sd915; //&#xa;PP_ROUNDS = 3; //&#xa;PP_PIXEL_DEPTH = 125; //&#xa;PP_IN_FRAME_SIZE = 64; //&#xa;PP_DW_K_H = 3; //&#xa;PP_DW_K_W = 3; //&#xa;PP_OUT_PIXEL_W = 8; //&#xa;POOL_DATA_W = 8; //&#xa;POOL_ROW_LEN = 25; //&#xa;POOL_ROW_NUM = 5; //&#xa;POOL_CHANNELS = 64; //&#xa;POOL_SUM_W = 16; //&#xa;FC_DATA_W = 8; //&#xa;FC_IN_CH = 64; //&#xa;FC_OUT_CLASS = 12; //&#xa;FC_WEIGHT_W = 8; //&#xa;FC_BIAS_W = 32; //&#xa;FC_ACC_W = FC_ACC_W; //&#xa;FC_Q_MUL = 239; //&#xa;FC_Q_SHIFT = 16; //&#xa;FC_Q_OFFSET = 128; //&#xa;DS_COEFF_FILE = &quot;./data/weights/DS-CNN_dw0.memh&quot;; //&#xa;DS_BIAS_FILE = &quot;./data/bias/DS-CNN_dw0_Fold_bias.hex&quot;; //&#xa;PP_DW_COEFF_FILE = &quot;./data/weights/DS-CNN_pingpong_dw.memh&quot;; //&#xa;PP_PW_COEFF_FILE = &quot;./data/weights/DS-CNN_pingpong_pw.memh&quot;; //&#xa;PP_DW_BIAS_FILE = &quot;./data/bias/DS-CNN_dw_pingpong_bias.hex&quot;; //&#xa;PP_PW_BIAS_FILE = &quot;./data/bias/DS-CNN_pw_pingpong_bias.hex&quot;; //&#xa;FC_WEIGHT_FILE = &quot;./data/DS-CNN_fc.memh&quot;; //&#xa;FC_BIAS_FILE = &quot;./data/DS-CNN_fc_bias.memh&quot;; //&#xa;" Parent="inference_cg_test" Type="model" Width="200" X="700" Y="430">
  <Port Color="#faebd7" Connect="" Datasize="DS_DATA_W-1:0" Datatype="wire" Description="" Height="30" Inout="input" Name="in_pixel" Parent="inference_cg0" Side="left" Width="30" X="-0.15" Y="0.0727273"/>
  <Port Color="#00ffff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="clk" Parent="inference_cg0" Side="left" Width="30" X="-0.15" Y="0.209091"/>
  <Port Color="#7fffd4" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="rst_n" Parent="inference_cg0" Side="left" Width="30" X="-0.15" Y="0.35"/>
  <Port Color="#f0ffff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="start" Parent="inference_cg0" Side="left" Width="30" X="-0.15" Y="0.495455"/>
  <Port Color="#f5f5dc" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="in_valid" Parent="inference_cg0" Side="left" Width="30" X="-0.15" Y="0.636364"/>
  <Port Color="#ffe4c4" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="out_ready" Parent="inference_cg0" Side="left" Width="30" X="-0.15" Y="0.777273"/>
  <Port Color="#b8860b" Connect="" Datasize="7:0" Datatype="wire " Description="" Height="30" Inout="output" Name="out_class" Parent="inference_cg0" Side="right" Width="30" X="0.85" Y="0.0909091"/>
  <Port Color="#ffebcd" Connect="" Datasize="FC_ACC_W-1:0" Datatype="wire " Description="" Height="30" Inout="output" Name="out_score" Parent="inference_cg0" Side="right" Width="30" X="0.85" Y="0.259091"/>
  <Port Color="#0000ff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="busy" Parent="inference_cg0" Side="right" Width="30" X="0.85" Y="0.418182"/>
  <Port Color="#8a2be2" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="in_ready" Parent="inference_cg0" Side="right" Width="30" X="0.85" Y="0.586364"/>
  <Port Color="#a52a2a" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="out_valid" Parent="inference_cg0" Side="right" Width="30" X="0.85" Y="0.75"/>
 </Module>
