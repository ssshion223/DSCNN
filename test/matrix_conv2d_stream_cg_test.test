 <Wire Datasize="DATA_W-1:0" Datatype="wire" From="matrix_conv2d_stream_cg_test>in_pixel" Name="matrix_conv2d_stream_cg_test_in_pixel" Parent="matrix_conv2d_stream_cg_test" To="matrix_conv2d_stream_cg_test#matrix_conv2d_stream_cg0>in_pixel"/>
 <Wire Datasize="ACC_W-1:0" Datatype="wire" From="matrix_conv2d_stream_cg_test>out_pixel_data" Name="matrix_conv2d_stream_cg0_out_pixel_data" Parent="matrix_conv2d_stream_cg_test" To="matrix_conv2d_stream_cg_test#matrix_conv2d_stream_cg0>out_pixel_data"/>
