 <Port Color="#00bfff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="busy" Parent="dw_pw_pingpong_ctrl_cg" Side="right" Width="30" X="0.98125" Y="0.393519"/>
 <Port Color="#696969" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="in_ready" Parent="dw_pw_pingpong_ctrl_cg" Side="right" Width="30" X="0.98125" Y="0.430556"/>
 <Port Color="#696969" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="out_valid" Parent="dw_pw_pingpong_ctrl_cg" Side="right" Width="30" X="0.98125" Y="0.465741"/>
