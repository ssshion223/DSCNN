 <Port Color="#b22222" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="output" Name="out_end_all_frame" Parent="dw_pw_pingpong_ctrl_cg" Side="right" Width="30" X="0.98125" Y="0.530556"/>
