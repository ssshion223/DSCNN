 <Port Color="#bdb76b" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="bias_process_out_valid" Parent="dw_pw_pingpong_ctrl_cg" Side="left" Width="30" X="-0.01875" Y="0.880556"/>
 <Port Color="#8b008b" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="bias_process_out_end_frame" Parent="dw_pw_pingpong_ctrl_cg" Side="left" Width="30" X="-0.01875" Y="0.918519"/>
