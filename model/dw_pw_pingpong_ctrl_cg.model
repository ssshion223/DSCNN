 <Port Color="#f0ffff" Connect="" Datasize="RAM_DATA_W-1:0" Datatype="wire " Description="" Height="30" Inout="input" Name="pw_conv_ram_wdata" Parent="dw_pw_pingpong_ctrl_cg" Side="left" Width="30" X="-0.01875" Y="0.118519"/>
 <Port Color="#f5f5dc" Connect="" Datasize="RAM_DATA_W-1:0" Datatype="wire " Description="" Height="30" Inout="input" Name="ram0_rdata" Parent="dw_pw_pingpong_ctrl_cg" Side="left" Width="30" X="-0.01875" Y="0.152778"/>
