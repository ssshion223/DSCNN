 <Port Color="#daa520" Connect="" Datasize="1" Datatype="reg" Description="" Height="30" Inout="output" Name="ram_reader_start" Parent="dw_pw_pingpong_ctrl_cg" Side="right" Width="30" X="0.98125" Y="0.768519"/>
