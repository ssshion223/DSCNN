  <Port Color="#00ffff" Connect="" Datasize="1" Datatype="wire" Description="" Height="30" Inout="input" Name="clk" Parent="bias_process_wrapper_cg2" Side="right" Width="30" X="0.92126" Y="0.0431655"/>
