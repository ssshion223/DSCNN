  <Port Color="#adff2f" Connect="" Datasize="1" Datatype="reg" Description="" Height="30" Inout="output" Name="bias_process_in_end_frame" Parent="dw_pw_pingpong_ctrl_cg3" Side="right" Width="30" X="0.974684" Y="0.295069"/>
  <Port Color="#808080" Connect="" Datasize="1" Datatype="reg" Description="" Height="30" Inout="output" Name="bias_process_in_end_all_frame" Parent="dw_pw_pingpong_ctrl_cg3" Side="right" Width="30" X="0.974684" Y="0.329022"/>
